// =============================================================================
// MELT-BACK — Prisma Schema (English)
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// AUTH & USERS
// =============================================================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  googleId  String?  @unique
  isGuest   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  corpora UserCorpus[]

  @@map("users")
}

model Corpus {
  id                  String   @id @default(uuid())
  name                String   @db.VarChar(200)
  description         String?
  wordCount           Int?
  discursiveCommunity String?  @db.VarChar(200)
  textualGenre        String?  @db.VarChar(100)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  users     UserCorpus[]
  documents Document[]

  @@map("corpus")
}

model UserCorpus {
  userId   String
  corpusId String
  role     UserCorpusRole @default(OWNER)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  corpus Corpus @relation(fields: [corpusId], references: [id], onDelete: Cascade)

  @@id([userId, corpusId])
  @@map("user_corpus")
}

enum UserCorpusRole {
  OWNER
  COLLABORATOR
  VIEWER
}

model Document {
  id           String        @id @default(uuid())
  corpusId     String
  title        String        @db.VarChar(300)
  description  String?
  date         DateTime?
  author       String?       @db.VarChar(200)
  documentType DocumentType?
  language     Language      @default(SPANISH)
  content      Bytes?
  pageCount    Int?
  tokenCount   Int?
  fileUrl      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  corpus   Corpus            @relation(fields: [corpusId], references: [id], onDelete: Cascade)
  analysis DocumentAnalysis?

  @@map("documents")
}

enum DocumentType {
  ACADEMIC_ARTICLE
  POLITICAL_SPEECH
  NEWS
  EDITORIAL
  INTERVIEW
  OFFICIAL_DOCUMENT
  SOCIAL_MEDIA
  OTHER
}

enum Language {
  SPANISH
  ENGLISH
}

// =============================================================================
// DOCUMENT ANALYSIS — Pipeline state control
// =============================================================================

model DocumentAnalysis {
  id         String     @id @default(uuid())
  documentId String     @unique
  aiProvider AiProvider @default(CLAUDE)

  level0Status LevelStatus @default(PENDING)
  level1Status LevelStatus @default(PENDING)
  level2Status LevelStatus @default(PENDING)
  level3Status LevelStatus @default(PENDING)
  level4Status LevelStatus @default(PENDING)
  level5Status LevelStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  document               Document               @relation(fields: [documentId], references: [id], onDelete: Cascade)
  primaryMetaphors       PrimaryMetaphor[]
  conventionalMetaphors  ConventionalMetaphor[]
  scenarios              MetaphoricalScenario[]
  regimes                MetaphorRegime[]
  culturalNarrative      CulturalNarrative?

  @@map("document_analyses")
}

enum LevelStatus {
  PENDING
  PROCESSING
  PENDING_REVIEW
  APPROVED
  OUTDATED
}

enum AiProvider {
  CLAUDE
  OPENAI
  HUGGINGFACE
}

// =============================================================================
// LEVEL 1 — PRIMARY METAPHORS
// =============================================================================

model PrimaryMetaphor {
  id                   String     @id @default(uuid())
  analysisId           String
  page                 Int?
  metaphoricalExpression String   @db.VarChar(500)
  context              String?
  focus                String?    @db.VarChar(100)
  focusLemma           String?    @db.VarChar(100)
  focusPartOfSpeech    String?    @db.VarChar(100)
  contextualMeaning    String?    @db.VarChar(500)
  basicMeaning         String?    @db.VarChar(500)
  sourceDomain         String?    @db.VarChar(200)
  targetDomain         String?    @db.VarChar(200)
  conceptualMetaphor   String?    @db.VarChar(500)
  itemStatus           ItemStatus @default(PENDING_REVIEW)
  aiGenerated          Boolean    @default(true)
  analystNote          String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  analysis                DocumentAnalysis             @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  ontologicalMappings     OntologicalMapping[]
  epistemicMappings       EpistemicMapping[]
  conventionalMetaphors   PrimaryMetaphorConventional[]

  @@map("primary_metaphors")
}

enum ItemStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  MODIFIED
}

model OntologicalMapping {
  id                String     @id @default(uuid())
  primaryMetaphorId String
  sourceElement     String     @db.VarChar(200)
  targetElement     String     @db.VarChar(200)
  textualEvidence   String?
  itemStatus        ItemStatus @default(PENDING_REVIEW)
  aiGenerated       Boolean    @default(true)
  analystNote       String?
  createdAt         DateTime   @default(now())

  primaryMetaphor PrimaryMetaphor @relation(fields: [primaryMetaphorId], references: [id], onDelete: Cascade)

  @@map("ontological_mappings")
}

model EpistemicMapping {
  id                String        @id @default(uuid())
  primaryMetaphorId String
  sourceRelation    String        @db.VarChar(300)
  targetInference   String        @db.VarChar(300)
  inferenceType     InferenceType
  textualEvidence   String?
  itemStatus        ItemStatus    @default(PENDING_REVIEW)
  aiGenerated       Boolean       @default(true)
  analystNote       String?
  createdAt         DateTime      @default(now())

  primaryMetaphor PrimaryMetaphor @relation(fields: [primaryMetaphorId], references: [id], onDelete: Cascade)

  @@map("epistemic_mappings")
}

enum InferenceType {
  CAUSAL
  TEMPORAL
  CONDITIONAL
  NORMATIVE
  EVALUATIVE
}

// =============================================================================
// LEVEL 2 — CONVENTIONAL METAPHORS
// =============================================================================

model ConventionalMetaphor {
  id                 String                       @id @default(uuid())
  analysisId         String
  conceptualMetaphor String                       @db.VarChar(500)
  sourceDomain       String                       @db.VarChar(200)
  targetDomain       String                       @db.VarChar(200)
  approach           ConventionalizationApproach
  absoluteFrequency  Int                          @default(0)
  textualDistribution Json?
  robustness         ConventionalizationRobustness
  usageContext       String?
  itemStatus         ItemStatus                   @default(PENDING_REVIEW)
  aiGenerated        Boolean                      @default(true)
  analystNote        String?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  analysis         DocumentAnalysis              @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  primaryMetaphors PrimaryMetaphorConventional[]
  scenarios        MetaphoricalScenario[]

  @@map("conventional_metaphors")
}

enum ConventionalizationApproach {
  FREQUENCY
  THEMATIC_CLUSTER
}

enum ConventionalizationRobustness {
  HIGH
  MODERATE
  WEAK
}

// M:N — PrimaryMetaphor <-> ConventionalMetaphor
model PrimaryMetaphorConventional {
  conventionalMetaphorId String
  primaryMetaphorId      String

  conventionalMetaphor ConventionalMetaphor @relation(fields: [conventionalMetaphorId], references: [id], onDelete: Cascade)
  primaryMetaphor      PrimaryMetaphor      @relation(fields: [primaryMetaphorId], references: [id], onDelete: Cascade)

  @@id([conventionalMetaphorId, primaryMetaphorId])
  @@map("primary_metaphor_conventional")
}

// =============================================================================
// LEVEL 3 — METAPHORICAL SCENARIOS
// =============================================================================

model MetaphoricalScenario {
  id                     String          @id @default(uuid())
  analysisId             String
  conventionalMetaphorId String
  scenarioName           String          @db.VarChar(200)
  mappingIds             String[]
  status                 ScenarioStatus
  usageValuation         UsageValuation
  itemStatus             ItemStatus      @default(PENDING_REVIEW)
  aiGenerated            Boolean         @default(true)
  analystNote            String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  analysis             DocumentAnalysis      @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  conventionalMetaphor ConventionalMetaphor  @relation(fields: [conventionalMetaphorId], references: [id], onDelete: Cascade)
  socialGroups         PositionedSocialGroup[]
  narrativeSequence    NarrativeSequence?
  evaluativeBias       EvaluativeBias?
  affects              Affect[]
  regimes              ScenarioRegime[]

  @@map("metaphorical_scenarios")
}

enum ScenarioStatus {
  DOMINANT
  CHALLENGER
  EMERGING
  PERIPHERAL
}

enum UsageValuation {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

model PositionedSocialGroup {
  id                  String     @id @default(uuid())
  scenarioId          String
  socialGroup         String     @db.VarChar(200)
  legitimizedActions  String[]
  itemStatus          ItemStatus @default(PENDING_REVIEW)
  aiGenerated         Boolean    @default(true)
  analystNote         String?
  createdAt           DateTime   @default(now())

  scenario MetaphoricalScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@map("positioned_social_groups")
}

model NarrativeSequence {
  id             String       @id @default(uuid())
  scenarioId     String       @unique
  act1Beginning  String
  act2Development String
  act3Resolution String
  sequenceType   SequenceType
  itemStatus     ItemStatus   @default(PENDING_REVIEW)
  aiGenerated    Boolean      @default(true)
  analystNote    String?
  createdAt      DateTime     @default(now())

  scenario MetaphoricalScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@map("narrative_sequences")
}

enum SequenceType {
  TEMPORAL
  CAUSAL
}

model EvaluativeBias {
  id          String     @id @default(uuid())
  scenarioId  String     @unique
  positive    String[]
  negative    String[]
  itemStatus  ItemStatus @default(PENDING_REVIEW)
  aiGenerated Boolean    @default(true)
  analystNote String?
  createdAt   DateTime   @default(now())

  scenario MetaphoricalScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@map("evaluative_biases")
}

model Affect {
  id                  String     @id @default(uuid())
  scenarioId          String
  affectType          AffectType
  affectName          String     @db.VarChar(200)
  description         String?
  socialFunction      String?
  linguisticMarkers   String?
  itemStatus          ItemStatus @default(PENDING_REVIEW)
  aiGenerated         Boolean    @default(true)
  analystNote         String?
  createdAt           DateTime   @default(now())

  scenario MetaphoricalScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@map("affects")
}

enum AffectType {
  FACILITATED
  INHIBITED
}

// =============================================================================
// LEVEL 4 — METAPHOR REGIMES
// =============================================================================

model MetaphorRegime {
  id                 String     @id @default(uuid())
  analysisId         String
  regimeName         String     @db.VarChar(300)
  aggregateFrequency Int        @default(0)
  metaphors          String[]
  itemStatus         ItemStatus @default(PENDING_REVIEW)
  aiGenerated        Boolean    @default(true)
  analystNote        String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  analysis         DocumentAnalysis          @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  scenarios        ScenarioRegime[]
  derivedMetaphors RegimeDerivedMetaphor[]
  valueAxis        ValueAxis?
  culturalNarrative CulturalNarrative?

  @@map("metaphor_regimes")
}

// M:N — MetaphoricalScenario <-> MetaphorRegime
model ScenarioRegime {
  regimeId   String
  scenarioId String

  regime   MetaphorRegime       @relation(fields: [regimeId], references: [id], onDelete: Cascade)
  scenario MetaphoricalScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@id([regimeId, scenarioId])
  @@map("scenario_regimes")
}

model RegimeDerivedMetaphor {
  id              String     @id @default(uuid())
  regimeId        String
  derivedMetaphor String
  itemStatus      ItemStatus @default(PENDING_REVIEW)
  aiGenerated     Boolean    @default(true)
  analystNote     String?
  createdAt       DateTime   @default(now())

  regime MetaphorRegime @relation(fields: [regimeId], references: [id], onDelete: Cascade)

  @@map("regime_derived_metaphors")
}

model ValueAxis {
  id               String     @id @default(uuid())
  regimeId         String     @unique
  axisName         String     @db.VarChar(200)
  positivePolarity String[]
  negativePolarity String[]
  evidence         String?
  itemStatus       ItemStatus @default(PENDING_REVIEW)
  aiGenerated      Boolean    @default(true)
  analystNote      String?
  createdAt        DateTime   @default(now())

  regime MetaphorRegime @relation(fields: [regimeId], references: [id], onDelete: Cascade)

  @@map("value_axes")
}

// =============================================================================
// LEVEL 5 — CULTURAL NARRATIVE
// =============================================================================

model CulturalNarrative {
  id                  String     @id @default(uuid())
  analysisId          String     @unique
  regimeId            String     @unique
  name                String     @db.VarChar(300)
  description         String?    @db.VarChar(1000)
  textualDistribution String[]
  itemStatus          ItemStatus @default(PENDING_REVIEW)
  aiGenerated         Boolean    @default(true)
  analystNote         String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  analysis DocumentAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  regime   MetaphorRegime   @relation(fields: [regimeId], references: [id], onDelete: Cascade)

  @@map("cultural_narratives")
}

// =============================================================================
// CONSOLIDATED ANALYSIS (multi-document, corpus level)
// =============================================================================

model ConsolidatedAnalysis {
  id           String     @id @default(uuid())
  corpusId     String
  name         String     @db.VarChar(300)
  documentIds  String[]
  aiProvider   AiProvider @default(CLAUDE)

  level2Status LevelStatus @default(PENDING)
  level3Status LevelStatus @default(PENDING)
  level4Status LevelStatus @default(PENDING)
  level5Status LevelStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conventionalMetaphors ConsolidatedConventionalMetaphor[]
  scenarios             ConsolidatedScenario[]
  regimes               ConsolidatedRegime[]
  culturalNarrative     ConsolidatedNarrative?

  @@map("consolidated_analyses")
}

model ConsolidatedConventionalMetaphor {
  id                     String                        @id @default(uuid())
  consolidatedAnalysisId String
  conceptualMetaphor     String                        @db.VarChar(500)
  sourceDomain           String                        @db.VarChar(200)
  targetDomain           String                        @db.VarChar(200)
  approach               ConventionalizationApproach
  absoluteFrequency      Int                           @default(0)
  textualDistribution    Json?
  robustness             ConventionalizationRobustness
  itemStatus             ItemStatus                    @default(PENDING_REVIEW)
  aiGenerated            Boolean                       @default(true)
  analystNote            String?
  createdAt              DateTime                      @default(now())

  consolidatedAnalysis ConsolidatedAnalysis       @relation(fields: [consolidatedAnalysisId], references: [id], onDelete: Cascade)
  scenarios            ConsolidatedScenario[]

  @@map("consolidated_conventional_metaphors")
}

model ConsolidatedScenario {
  id                               String         @id @default(uuid())
  consolidatedAnalysisId           String
  consolidatedConventionalMetaphorId String
  scenarioName                     String         @db.VarChar(200)
  status                           ScenarioStatus
  usageValuation                   UsageValuation
  itemStatus                       ItemStatus     @default(PENDING_REVIEW)
  aiGenerated                      Boolean        @default(true)
  analystNote                      String?
  createdAt                        DateTime       @default(now())

  consolidatedAnalysis  ConsolidatedAnalysis             @relation(fields: [consolidatedAnalysisId], references: [id], onDelete: Cascade)
  conventionalMetaphor  ConsolidatedConventionalMetaphor @relation(fields: [consolidatedConventionalMetaphorId], references: [id], onDelete: Cascade)
  regimes               ConsolidatedRegimeScenario[]

  @@map("consolidated_scenarios")
}

model ConsolidatedRegime {
  id                     String     @id @default(uuid())
  consolidatedAnalysisId String
  regimeName             String     @db.VarChar(300)
  aggregateFrequency     Int        @default(0)
  itemStatus             ItemStatus @default(PENDING_REVIEW)
  aiGenerated            Boolean    @default(true)
  analystNote            String?
  createdAt              DateTime   @default(now())

  consolidatedAnalysis ConsolidatedAnalysis         @relation(fields: [consolidatedAnalysisId], references: [id], onDelete: Cascade)
  scenarios            ConsolidatedRegimeScenario[]
  culturalNarrative    ConsolidatedNarrative?

  @@map("consolidated_regimes")
}

model ConsolidatedRegimeScenario {
  consolidatedRegimeId   String
  consolidatedScenarioId String

  regime   ConsolidatedRegime   @relation(fields: [consolidatedRegimeId], references: [id], onDelete: Cascade)
  scenario ConsolidatedScenario @relation(fields: [consolidatedScenarioId], references: [id], onDelete: Cascade)

  @@id([consolidatedRegimeId, consolidatedScenarioId])
  @@map("consolidated_regime_scenarios")
}

model ConsolidatedNarrative {
  id                     String     @id @default(uuid())
  consolidatedAnalysisId String     @unique
  consolidatedRegimeId   String     @unique
  name                   String     @db.VarChar(300)
  description            String?    @db.VarChar(1000)
  itemStatus             ItemStatus @default(PENDING_REVIEW)
  aiGenerated            Boolean    @default(true)
  analystNote            String?
  createdAt              DateTime   @default(now())

  consolidatedAnalysis ConsolidatedAnalysis @relation(fields: [consolidatedAnalysisId], references: [id], onDelete: Cascade)
  regime               ConsolidatedRegime   @relation(fields: [consolidatedRegimeId], references: [id], onDelete: Cascade)

  @@map("consolidated_narratives")
}
